{
  "name": "@datafix/n8n-nodes-pdf2img",
  "version": "0.1.4",
  "description": "A custom n8n node that converts PDF files to PNG images using the PDFium library for rendering and Sharp for image processing.",
  "license": "MIT",
  "homepage": "",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "DataFix B.V.",
    "email": "nodes@datafix.nl"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/datafix/n8n-nodes-pdf2img.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [],
    "nodes": [
      "dist/nodes/pdf2img/pdf2img.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.32.0",
    "prettier": "3.6.2",
    "release-it": "^19.0.4",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "@hyzyla/pdfium": "^2.1.12",
    "sharp": "^0.34.5"
  }
}
